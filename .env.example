# ──────────────────────────────────────────────────────────────────────────
# AI Tool Directory — environment variables
# Copy to .env.local for local dev. In Vercel, add these in Project Settings.
# Only DATABASE_URL is strictly required for the site to render data.
# Clerk / Stripe features degrade gracefully when their keys are absent.
# ──────────────────────────────────────────────────────────────────────────

# Public base URL (no trailing slash). Used for canonical URLs, sitemap, OG, Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Neon Postgres) ────────────────────────────────────────────────
# Neon: use the POOLED connection string. Works with any standard Postgres too.
# Example (Neon):  postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
# Example (local): postgresql://postgres:postgres@localhost:5432/ai_directory
DATABASE_URL=

# ── Clerk (auth for /submit and /admin only; browsing needs no login) ───────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Comma-separated list of admin email addresses allowed into /admin.
ADMIN_EMAILS=

# ── Stripe (self-serve "Featured" placements) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for the monthly "Featured" subscription (create a recurring Price in Stripe).
NEXT_PUBLIC_STRIPE_FEATURED_PRICE_ID=

# ── Anthropic Claude (used by the Python ingestion pipeline) ────────────────
ANTHROPIC_API_KEY=
# Model used for extraction / classification in the ingester.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Firecrawl (optional alternative crawler for the ingester) ───────────────
FIRECRAWL_API_KEY=

# ── Plausible analytics (optional) ──────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Ingestion tuning (optional) ─────────────────────────────────────────────
# Max tools to fetch per source per run.
INGEST_MAX_PER_SOURCE=60
